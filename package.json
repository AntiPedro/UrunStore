{
  "name": "urun-store",
  "version": "1.0.0",
  "description": "Ürün Store - Premium Oyun ve İçerik Mağazası",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "author": "Ürün Studio",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.urun.store",
    "productName": "Ürün Store",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ürün Store"
    },
    "files": [
      "main.js",
      "preload.js",
      "store.html",
      "assets/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "AntiPedro",
        "repo": "UrunStore"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
